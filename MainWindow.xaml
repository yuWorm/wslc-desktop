<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="wslc_desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:wslc_desktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="using:H.NotifyIcon"
    Title="wslc-desktop"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            x:Uid="AppTitleBar"
            Title="WSLC Desktop"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
            <TitleBar.RightHeader>
                <Button
                    x:Name="ShellStatusButton"
                    AutomationProperties.AutomationId="ShellStatusButton"
                    MinHeight="32"
                    MaxWidth="360"
                    Margin="0,0,8,0"
                    Padding="10,4">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="12" Glyph="&#xE930;" />
                            <TextBlock
                                MaxLines="1"
                                Text="{x:Bind ShellStatus.SummaryText, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button.Content>
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <StackPanel Width="380" Spacing="12">
                                <TextBlock
                                    x:Uid="ShellStatusFlyoutTitle"
                                    Style="{ThemeResource SubtitleTextBlockStyle}"
                                    Text="Runtime status" />

                                <Grid ColumnSpacing="16" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Uid="ShellStatusDaemonLabel" Grid.Row="0" Text="Daemon" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ShellStatus.DaemonText, Mode=OneWay}" TextWrapping="Wrap" />

                                    <TextBlock x:Uid="ShellStatusBackendLabel" Grid.Row="1" Text="Backend" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ShellStatus.BackendText, Mode=OneWay}" TextWrapping="Wrap" />

                                    <TextBlock x:Uid="ShellStatusRuntimeLabel" Grid.Row="2" Text="Runtime" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ShellStatus.RuntimeText, Mode=OneWay}" TextWrapping="Wrap" />

                                    <TextBlock x:Uid="ShellStatusPipeLabel" Grid.Row="3" Text="Pipe" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ShellStatus.PipeHealth, Mode=OneWay}" TextWrapping="Wrap" />

                                    <TextBlock x:Uid="ShellStatusMessageLabel" Grid.Row="4" Text="Message" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" MaxLines="4" Text="{x:Bind ShellStatus.Message, Mode=OneWay}" TextWrapping="Wrap" />

                                    <TextBlock x:Uid="ShellStatusLogsLabel" Grid.Row="5" Text="Logs" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" MaxLines="3" Text="{x:Bind ShellStatus.LogFilesText, Mode=OneWay}" TextWrapping="Wrap" />
                                </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Click="RefreshShellStatus_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                            <TextBlock x:Uid="ShellStatusRefreshText" Text="Refresh" />
                                        </StackPanel>
                                    </Button>
                                    <Button Click="StartDaemonFromStatus_Click" IsEnabled="{x:Bind ShellStatus.CanStartDaemon, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="14" Glyph="&#xE768;" />
                                            <TextBlock x:Uid="ShellStatusStartText" Text="Start" />
                                        </StackPanel>
                                    </Button>
                                    <Button Click="RestartDaemonFromStatus_Click" IsEnabled="{x:Bind ShellStatus.CanRestartDaemon, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="14" Glyph="&#xE777;" />
                                            <TextBlock x:Uid="ShellStatusRestartText" Text="Restart" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Click="StopDaemonFromStatus_Click" IsEnabled="{x:Bind ShellStatus.CanStopDaemon, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="14" Glyph="&#xE71A;" />
                                            <TextBlock x:Uid="ShellStatusStopText" Text="Stop" />
                                        </StackPanel>
                                    </Button>
                                    <Button Click="OpenSettingsFromStatus_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="14" Glyph="&#xE713;" />
                                            <TextBlock x:Uid="ShellStatusSettingsText" Text="Settings" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </TitleBar.RightHeader>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            AutomationProperties.AutomationId="NavRoot"
            Grid.Row="1"
            IsEnabled="False"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem AutomationProperties.AutomationId="NavContainers" x:Name="NavContainers" x:Uid="NavContainers" Content="Containers" IsSelected="True" Tag="containers">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem AutomationProperties.AutomationId="NavImages" x:Uid="NavImages" Content="Images" Tag="images">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEB9F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem AutomationProperties.AutomationId="NavVolumes" x:Uid="NavVolumes" Content="Volumes" Tag="volumes">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEDA2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem AutomationProperties.AutomationId="NavNetworks" x:Uid="NavNetworks" Content="Networks" Tag="networks">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE839;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem AutomationProperties.AutomationId="NavCompose" x:Uid="NavCompose" Content="Compose" Tag="compose">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="NavFrame" AutomationProperties.AutomationId="MainFrame" />
        </NavigationView>

        <tb:TaskbarIcon
            x:Name="TrayIcon"
            Width="0"
            Height="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipText="WSLC Desktop"
            IconSource="Assets/AppIcon.ico"
            LeftClickCommand="{x:Bind ShowMainWindowCommand}"
            NoLeftClickDelay="True"
            MenuActivation="RightClick">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem x:Uid="TrayMainWindowItem" Text="Main window" Command="{x:Bind ShowMainWindowCommand}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8A7;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Uid="TraySettingsItem" Text="Settings" Command="{x:Bind ShowSettingsCommand}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE713;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Uid="TrayStartDaemonItem" Text="Start daemon" Command="{x:Bind StartDaemonCommand}" IsEnabled="{x:Bind ShellStatus.CanStartDaemon, Mode=OneWay}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE768;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Uid="TrayRestartDaemonItem" Text="Restart daemon" Command="{x:Bind RestartDaemonCommand}" IsEnabled="{x:Bind ShellStatus.CanRestartDaemon, Mode=OneWay}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE777;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Uid="TrayStopDaemonItem" Text="Stop daemon" Command="{x:Bind StopDaemonCommand}" IsEnabled="{x:Bind ShellStatus.CanStopDaemon, Mode=OneWay}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE71A;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Uid="TrayExitItem" Text="Exit" Command="{x:Bind ExitApplicationCommand}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8BB;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>
    </Grid>
</Window>
