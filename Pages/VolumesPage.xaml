<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="wslc_desktop.Pages.VolumesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="18,14,18,18" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock x:Uid="VolumesTitle" Style="{StaticResource TitleTextBlockStyle}" Text="Volumes" />
                    <ProgressRing Height="18" IsActive="{Binding IsLoading}" Width="18" />
                    <ProgressRing Height="18" IsActive="{Binding IsBusy}" Width="18" />
                </StackPanel>
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding VolumeSummaryText}" />
            </StackPanel>

            <TextBox
                x:Uid="VolumesSearchBox"
                AutomationProperties.AutomationId="TxtVolumesSearch"
                Grid.Column="1"
                PlaceholderText="Filter..."
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VerticalAlignment="Center" />

            <Button
                x:Uid="VolumesNewButton"
                AutomationProperties.AutomationId="BtnVolumesCreate"
                Grid.Column="2"
                Click="NewVolume_Click"
                VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                    <TextBlock x:Uid="VolumesNewButtonText" Text="New Volume" />
                </StackPanel>
            </Button>

            <Button
                x:Uid="RefreshButton"
                AutomationProperties.AutomationId="BtnVolumesRefresh"
                Grid.Column="3"
                Command="{Binding RefreshCommand}"
                VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    <TextBlock x:Uid="RefreshButtonText" Text="Refresh" />
                </StackPanel>
            </Button>

            <Button
                x:Uid="DeleteButton"
                AutomationProperties.AutomationId="BtnVolumesDelete"
                Grid.Column="4"
                Click="DeleteVolume_Click"
                IsEnabled="{Binding CanDeleteSelectedVolume}"
                VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                    <TextBlock x:Uid="DeleteButtonText" Text="Delete" />
                </StackPanel>
            </Button>
        </Grid>

        <InfoBar
            x:Uid="VolumesLoadFailedInfo"
            Grid.Row="1"
            IsOpen="{Binding HasError}"
            Message="{Binding ErrorMessage}"
            Severity="Error"
            Title="Volume load failed" />

        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <InfoBar
                    x:Uid="VolumesEmptyInfo"
                    Grid.Row="0"
                    IsOpen="{Binding IsEmpty}"
                    Message="Create a container with a mount mapping such as C:\data=>/data to populate this view."
                    Severity="Informational"
                    Title="No mounts" />

                <Grid Grid.Row="1" Padding="16,10" ColumnSpacing="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.4*" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="ColumnName" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="NAME" />
                    <TextBlock x:Uid="ColumnSize" Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="SIZE" />
                    <TextBlock x:Uid="ColumnDriver" Grid.Column="2" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="DRIVER" />
                    <TextBlock x:Uid="ColumnUsedBy" Grid.Column="3" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="USED BY" />
                    <TextBlock x:Uid="ColumnCreated" Grid.Column="4" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="CREATED" />
                    <TextBlock x:Uid="ColumnActions" Grid.Column="5" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="ACTIONS" />
                </Grid>

                <ListView
                    x:Name="VolumesList"
                    Grid.Row="2"
                    AutomationProperties.AutomationId="LstVolumes"
                    ItemsSource="{Binding VisibleVolumes}"
                    SelectedItem="{Binding SelectedVolume, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="62" Padding="14,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.4*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <Border Width="34" Height="34" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                                        <FontIcon FontSize="17" Glyph="&#xE7B8;" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                    </Border>
                                    <StackPanel MinWidth="0" Spacing="2">
                                        <TextBlock FontFamily="Cascadia Mono" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding KindText}" />
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="{Binding Size}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding KindText}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{Binding UsedBy}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="{Binding Created}" VerticalAlignment="Center" />

                                <Button Grid.Column="5" Click="ShowVolumeDetail_Click" Padding="8,4" VerticalAlignment="Center">
                                    <FontIcon FontSize="12" Glyph="&#xE946;" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
