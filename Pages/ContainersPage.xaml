<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="wslc_desktop.Pages.ContainersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="18,14,18,18" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock x:Uid="ContainersTitle" Style="{StaticResource TitleTextBlockStyle}" Text="Containers" />
                    <ProgressRing Height="18" IsActive="{Binding IsLoading}" Width="18" />
                </StackPanel>
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ContainerSummaryText}" />
            </StackPanel>

            <TextBox
                x:Uid="ContainersSearchBox"
                AutomationProperties.AutomationId="TxtContainerSearch"
                Grid.Column="1"
                PlaceholderText="Search containers"
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VerticalAlignment="Center" />

            <ComboBox
                x:Uid="ContainersStatusFilter"
                AutomationProperties.AutomationId="ContainerStatusFilter"
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                SelectedValue="{Binding SelectedStateFilter, Mode=TwoWay}"
                SelectedValuePath="Tag"
                VerticalAlignment="Center">
                <ComboBoxItem x:Uid="ContainersFilterAll" Content="All" Tag="All" />
                <ComboBoxItem x:Uid="ContainersFilterRunning" Content="Running" Tag="Running" />
                <ComboBoxItem x:Uid="ContainersFilterStopped" Content="Stopped" Tag="Stopped" />
            </ComboBox>

            <Button
                x:Uid="ContainersNewButton"
                AutomationProperties.AutomationId="BtnCreateContainer"
                Grid.Column="3"
                Click="CreateContainer_Click"
                VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                    <TextBlock x:Uid="ContainersNewButtonText" Text="New Container" />
                </StackPanel>
            </Button>

            <Button
                x:Uid="RefreshButton"
                AutomationProperties.AutomationId="BtnRefreshContainers"
                Grid.Column="4"
                Click="Refresh_Click"
                VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    <TextBlock x:Uid="RefreshButtonText" Text="Refresh" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="430" />
            </Grid.ColumnDefinitions>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <InfoBar
                        x:Uid="ContainersLoadFailedInfo"
                        Grid.Row="0"
                        IsOpen="{Binding HasError}"
                        Message="{Binding ErrorMessage}"
                        Severity="Error"
                        Title="Container load failed" />

                    <Grid Grid.Row="1" Padding="16,10" ColumnSpacing="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.3*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="104" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="88" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="ColumnName" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="NAME" />
                        <TextBlock x:Uid="ColumnImage" Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="IMAGE" />
                        <TextBlock x:Uid="ColumnCpu" Grid.Column="2" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="CPU" />
                        <TextBlock x:Uid="ColumnMemory" Grid.Column="3" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="MEMORY" />
                        <TextBlock x:Uid="ColumnPorts" Grid.Column="4" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="PORTS" />
                        <TextBlock x:Uid="ColumnState" Grid.Column="5" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="STATE" />
                    </Grid>

                    <ListView
                        x:Name="ContainerList"
                        AutomationProperties.AutomationId="ContainerList"
                        Grid.Row="2"
                        ItemsSource="{Binding VisibleContainers}"
                        SelectedItem="{Binding SelectedContainer, Mode=TwoWay}"
                        SelectionChanged="ContainerList_SelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="52" Padding="12,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.3*" />
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="88" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="2">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontFamily="Cascadia Mono" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Id}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" FontSize="13" Text="{Binding Image}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" FontFamily="Cascadia Mono" FontSize="13" Text="{Binding CpuPercent}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" FontFamily="Cascadia Mono" FontSize="13" Text="{Binding MemoryUsed}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" FontFamily="Cascadia Mono" FontSize="12" Text="{Binding PortSummary}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />

                                    <Border Grid.Column="5" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10" HorizontalAlignment="Left" Padding="8,3" VerticalAlignment="Center">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding State}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="3">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="11" Glyph="&#xEA3B;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedContainerName}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding SelectedContainerImage}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="8,3" VerticalAlignment="Top">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding SelectedContainerState}" />
                        </Border>
                    </Grid>

                    <CommandBar Grid.Row="1" DefaultLabelPosition="Right" IsOpen="False" OverflowButtonVisibility="Collapsed">
                        <AppBarButton x:Uid="ContainersStartCommand" Command="{Binding StartCommand}" Label="Start">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE768;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Uid="ContainersStopCommand" Command="{Binding StopCommand}" Label="Stop">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE71A;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Uid="ContainersRestartCommand" Command="{Binding RestartCommand}" Label="Restart">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE72C;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton x:Uid="DeleteCommand" Click="DeleteSelected_Click" IsEnabled="{Binding CanDeleteSelectedContainer}" Label="Delete">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE74D;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar>

                    <SelectorBar x:Name="ContainersDetailSelector" AutomationProperties.AutomationId="ContainersDetailSelector" Grid.Row="2" SelectionChanged="ContainersDetailSelector_SelectionChanged">
                        <SelectorBarItem x:Name="OverviewSelectorItem" x:Uid="ContainersOverviewSelector" Text="Overview" />
                        <SelectorBarItem x:Name="StatsSelectorItem" x:Uid="ContainersStatsSelector" Text="Stats" />
                        <SelectorBarItem x:Name="LogsSelectorItem" x:Uid="ContainersLogsSelector" Text="Logs" />
                        <SelectorBarItem x:Name="TerminalSelectorItem" x:Uid="ContainersTerminalSelector" Text="Terminal" />
                        <SelectorBarItem x:Name="EnvSelectorItem" x:Uid="ContainersEnvSelector" Text="Env" />
                        <SelectorBarItem x:Name="InspectSelectorItem" x:Uid="ContainersInspectSelector" Text="Inspect" />
                    </SelectorBar>

                    <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <StackPanel x:Name="OverviewPane" Spacing="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="ContainersOverviewQuickActionsHeading" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Quick actions" VerticalAlignment="Center" />
                                    <Button x:Uid="ContainersOverviewOpenTerminalButton" AutomationProperties.AutomationId="ContainersOverviewOpenTerminalButton" Grid.Column="1" Command="{Binding ExternalTerminalCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE8A7;" />
                                            <TextBlock x:Uid="ContainersOverviewOpenTerminalButtonText" Text="Open Terminal" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Uid="ColumnCpu" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="CPU" />
                                            <TextBlock FontFamily="Cascadia Mono" FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedContainerCpuText}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Uid="ColumnMemory" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="MEMORY" />
                                            <TextBlock FontFamily="Cascadia Mono" FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedContainerMemoryText}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid RowSpacing="8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Uid="ContainerDetailIdLabel" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="ID" />
                                    <TextBlock Grid.Column="1" FontFamily="Cascadia Mono" FontSize="12" Text="{Binding SelectedContainerId}" TextWrapping="WrapWholeWords" />
                                    <TextBlock x:Uid="ContainerDetailCommandLabel" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Command" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" FontFamily="Cascadia Mono" FontSize="12" Text="{Binding SelectedContainerCommand}" TextWrapping="WrapWholeWords" />
                                    <TextBlock x:Uid="ContainerDetailCreatedLabel" Grid.Row="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Created" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedContainerCreated}" />
                                    <TextBlock x:Uid="ContainerDetailUptimeLabel" Grid.Row="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Uptime" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedContainerUptime}" />
                                    <TextBlock x:Uid="ContainerDetailPortsLabel" Grid.Row="4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Ports" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedContainerPorts}" TextWrapping="WrapWholeWords" />
                                </Grid>

                                <StackPanel Spacing="8">
                                    <TextBlock x:Uid="ContainersPortsHeading" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Published ports" />
                                    <ItemsControl ItemsSource="{Binding SelectedContainerPortLinks}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Click="OpenPort_Click" Margin="0,0,6,6" Padding="8,3" Tag="{Binding Url}">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <TextBlock FontFamily="Cascadia Mono" Text="{Binding Label}" />
                                                        <FontIcon FontSize="11" Glyph="&#xE8A7;" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="StatsPane" Spacing="12" Visibility="Collapsed">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Uid="ColumnCpu" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="CPU" />
                                            <TextBlock FontFamily="Cascadia Mono" FontSize="22" FontWeight="SemiBold" Text="{Binding SelectedContainerCpuText}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Uid="ColumnMemory" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="MEMORY" />
                                            <TextBlock FontFamily="Cascadia Mono" FontSize="22" FontWeight="SemiBold" Text="{Binding SelectedContainerMemoryText}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <InfoBar x:Uid="ContainersStatsSnapshotInfo" IsOpen="True" Severity="Informational" Message="Current wslc stats snapshots are shown here; historical charts can be added later." />
                            </StackPanel>

                            <StackPanel x:Name="LogsPane" Spacing="10" Visibility="Collapsed">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Uid="ContainersLogsPreviewHeading" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Logs preview" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding SelectedContainerId}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button x:Uid="ContainersExpandLogsButton" Grid.Column="1" Click="ShowLogsDialog_Click" Content="Expand" IsEnabled="{Binding HasSelectedContainer}" />
                                </Grid>
                                <TextBox AcceptsReturn="True" FontFamily="Cascadia Mono" FontSize="12" Height="300" IsReadOnly="True" Text="{Binding SelectedContainerLogsPreview}" TextWrapping="NoWrap" />
                            </StackPanel>

                            <StackPanel x:Name="TerminalPane" Spacing="10" Visibility="Collapsed">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Uid="ContainersTerminalPreviewHeading" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Terminal" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding TerminalStateText}" />
                                    </StackPanel>
                                    <Button x:Uid="ContainersExpandTerminalButton" Grid.Column="1" Click="ShowTerminalDialog_Click" Content="Expand" IsEnabled="{Binding HasSelectedContainer}" />
                                </Grid>

                                <CommandBar Background="Transparent" DefaultLabelPosition="Right" IsOpen="False" OverflowButtonVisibility="Collapsed" Padding="0">
                                    <AppBarButton x:Uid="ExternalTerminalButton" Command="{Binding ExternalTerminalCommand}" Label="Open Terminal">
                                        <AppBarButton.Icon>
                                            <FontIcon Glyph="&#xE8A7;" />
                                        </AppBarButton.Icon>
                                    </AppBarButton>
                                    <AppBarButton x:Uid="ConnectTerminalButton" Command="{Binding ConnectTerminalCommand}" Label="Embedded Preview">
                                        <AppBarButton.Icon>
                                            <FontIcon Glyph="&#xE756;" />
                                        </AppBarButton.Icon>
                                    </AppBarButton>
                                    <AppBarButton x:Uid="DisconnectTerminalButton" Command="{Binding DisconnectTerminalCommand}" Label="Disconnect">
                                        <AppBarButton.Icon>
                                            <FontIcon Glyph="&#xE711;" />
                                        </AppBarButton.Icon>
                                    </AppBarButton>
                                </CommandBar>

                                <InfoBar
                                    x:Uid="TerminalCapabilityInfo"
                                    IsOpen="{Binding HasSelectedContainer}"
                                    Message="Open Terminal launches a real interactive shell in Windows Terminal. Embedded Preview is a fallback transcript."
                                    Severity="Informational" />

                                <TextBox
                                    x:Name="TerminalTranscript"
                                    AcceptsReturn="True"
                                    FontFamily="Cascadia Mono"
                                    FontSize="12"
                                    Height="270"
                                    IsReadOnly="True"
                                    Text="{Binding TerminalTranscript}"
                                    TextWrapping="NoWrap" />

                                <TextBox
                                    x:Name="TerminalInputLine"
                                    x:Uid="TerminalInputLine"
                                    Header="Input"
                                    IsEnabled="{Binding IsTerminalConnected}"
                                    KeyDown="TerminalInputLine_KeyDown"
                                    Text="{Binding TerminalInputLine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel x:Name="EnvPane" Spacing="10" Visibility="Collapsed">
                                <TextBlock x:Uid="ContainersEnvHeading" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Environment" />
                                <ItemsControl ItemsSource="{Binding SelectedContainerEnvironmentEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,7" ColumnSpacing="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="145" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontFamily="Cascadia Mono" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Text="{Binding Key}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" FontFamily="Cascadia Mono" FontSize="12" Text="{Binding Value}" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel x:Name="InspectPane" Spacing="10" Visibility="Collapsed">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Uid="ContainersInspectPreviewHeading" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Inspect preview" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding SelectedContainerId}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button x:Uid="ContainersExpandInspectButton" Grid.Column="1" Click="ShowInspectDialog_Click" Content="Expand" IsEnabled="{Binding HasSelectedContainer}" />
                                </Grid>
                                <TextBox AcceptsReturn="True" FontFamily="Cascadia Mono" FontSize="12" Height="360" IsReadOnly="True" Text="{Binding SelectedContainerInspectPreview}" TextWrapping="NoWrap" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
