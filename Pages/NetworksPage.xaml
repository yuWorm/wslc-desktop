<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="wslc_desktop.Pages.NetworksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="18,14,18,18" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock x:Uid="NetworksTitle" Style="{StaticResource TitleTextBlockStyle}" Text="Networks" />
                    <ProgressRing Height="18" IsActive="{Binding IsLoading}" Width="18" />
                </StackPanel>
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding NetworkSummaryText}" />
            </StackPanel>

            <TextBox
                x:Uid="NetworksSearchBox"
                AutomationProperties.AutomationId="TxtNetworksSearch"
                Grid.Column="1"
                PlaceholderText="Filter..."
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VerticalAlignment="Center" />

            <Button
                x:Uid="NetworksNewButton"
                AutomationProperties.AutomationId="BtnNetworksCreate"
                Grid.Column="2"
                IsEnabled="False"
                VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                    <TextBlock x:Uid="NetworksNewButtonText" Text="New Network" />
                </StackPanel>
            </Button>

            <Button
                x:Uid="RefreshButton"
                AutomationProperties.AutomationId="BtnNetworksRefresh"
                Grid.Column="3"
                Command="{Binding RefreshCommand}"
                VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    <TextBlock x:Uid="RefreshButtonText" Text="Refresh" />
                </StackPanel>
            </Button>
        </Grid>

        <InfoBar
            x:Uid="NetworksLoadFailedInfo"
            Grid.Row="1"
            IsOpen="{Binding HasError}"
            Message="{Binding ErrorMessage}"
            Severity="Error"
            Title="Network load failed" />

        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <InfoBar
                    x:Uid="NetworksEmptyInfo"
                    Grid.Row="0"
                    IsOpen="{Binding IsEmpty}"
                    Message="Published port data appears after containers are created with port mappings."
                    Severity="Informational"
                    Title="No published ports" />

                <Grid Grid.Row="1" Padding="16,10" ColumnSpacing="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="ColumnContainer" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="CONTAINER" />
                    <TextBlock x:Uid="ColumnHostPort" Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="HOST PORT" />
                    <TextBlock x:Uid="ColumnContainerPort" Grid.Column="2" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="CONTAINER PORT" />
                    <TextBlock x:Uid="ColumnProtocol" Grid.Column="3" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="PROTOCOL" />
                    <TextBlock x:Uid="ColumnUrl" Grid.Column="4" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="URL" />
                    <TextBlock x:Uid="ColumnActions" Grid.Column="5" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="ACTIONS" />
                </Grid>

                <ListView
                    x:Name="NetworkEndpointsList"
                    AutomationProperties.AutomationId="LstNetworkEndpoints"
                    Grid.Row="2"
                    ItemsSource="{Binding VisibleEndpoints}"
                    SelectedItem="{Binding SelectedEndpoint, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="62" Padding="14,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <Border Width="34" Height="34" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                                        <FontIcon FontSize="17" Glyph="&#xEC27;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                    </Border>
                                    <StackPanel MinWidth="0" Spacing="2">
                                        <TextBlock FontFamily="Cascadia Mono" FontWeight="SemiBold" Text="{Binding ContainerName}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Url}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Grid.Column="1" FontFamily="Cascadia Mono" Text="{Binding HostPort}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontFamily="Cascadia Mono" Text="{Binding ContainerPort}" VerticalAlignment="Center" />
                                <Border Grid.Column="3" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10" HorizontalAlignment="Left" Padding="8,3" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Protocol}" />
                                </Border>
                                <TextBlock Grid.Column="4" Text="{Binding Url}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <Button Grid.Column="5" Click="ShowEndpointDetail_Click" Padding="8,4" VerticalAlignment="Center">
                                    <FontIcon FontSize="12" Glyph="&#xE946;" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
